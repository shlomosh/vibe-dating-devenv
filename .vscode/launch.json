{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Build Auth Service",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.service",
      "args": ["build", "auth"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend/src"
      }
    },
    {
      "name": "Debug: Deploy Auth Service",
      "type": "debugpy",
      "request": "launch",
      "module": "scripts.service",
      "args": ["deploy", "auth"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend/src"
      }
    },
    {
      "name": "Debug: Profile Functionality Test",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/src/services/user/aws_lambdas/test/test_functionality_profile.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend/src",
        "AWS_PROFILE": "vibe-dev"
      },
      "justMyCode": false,
      "stopOnEntry": false
    },
    {
      "name": "Debug Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Debug Vite Dev Server (HTTPS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:https",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Launch Chrome against localhost",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*",
        "vite:///src/*": "${webRoot}/*"
      },
      "userDataDir": "${workspaceFolder}/frontend/.vscode/chrome-debug-profile",
      "runtimeArgs": [
        "--disable-web-security",
        "--disable-features=VizDisplayCompositor",
        "--remote-debugging-port=9222"
      ]
    },
    {
      "name": "Launch Chrome with HTTPS",
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*",
        "vite:///src/*": "${webRoot}/*"
      },
      "userDataDir": "${workspaceFolder}/frontend/.vscode/chrome-debug-profile",
      "runtimeArgs": [
        "--disable-web-security",
        "--disable-features=VizDisplayCompositor",
        "--remote-debugging-port=9222",
        "--ignore-certificate-errors"
      ]
    },
    {
      "name": "Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*",
        "vite:///src/*": "${webRoot}/*"
      }
    }
  ]
}
